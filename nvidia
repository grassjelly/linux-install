#!/bin/bash

if curl -s -f --connect-timeout 3 -H "Metadata-Flavor: Google" \
    "http://metadata.google.internal/computeMetadata/v1/instance/id" > /dev/null 2>&1; then
    echo "GCP detected — using GCP GPU driver installer..."
    curl https://raw.githubusercontent.com/GoogleCloudPlatform/compute-gpu-installation/main/linux/install_gpu_driver.py \
        --output install_gpu_driver.py
    sudo python3 install_gpu_driver.py
else
    echo "Non-GCP detected — using standard apt install..."
    sudo apt-get update -y
    sudo apt-get install -y ubuntu-drivers-common
    sudo ubuntu-drivers autoinstall
fi

echo "INSTALLATION DONE!"
